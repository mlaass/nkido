// SoundFont — play a melody through the built-in General MIDI bank.
// `soundfont(pattern, "gm", preset)` routes pattern events into the
// SF2 synth: gate, freq, and velocity are extracted from the events.
//
// Preset 0 is Acoustic Grand Piano in the GM standard.

bpm = 110

melody = pat("c4 e4 g4 c5 ~ g4 e4 c4 d4 f4 a4 d5 ~ a4 f4 d4 e4 g4 b4 e5 ~ b4 g4 e4 c4@4 ~@4")

melody
    |> soundfont(%, "gm", 0)
    |> @ + freeverb(@, 0.65, 0.4) * 0.35
    |> out(@)
