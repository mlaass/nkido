{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "NKIDO_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "NKIDO_BUILD_TESTS": "OFF"
            }
        },
        {
            "name": "relwithdebinfo",
            "displayName": "Release with Debug Info",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "NKIDO_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "wasm",
            "displayName": "WebAssembly (Emscripten)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
                "NKIDO_BUILD_TESTS": "OFF",
                "NKIDO_BUILD_TOOLS": "OFF"
            }
        },
        {
            "name": "cedar-only",
            "displayName": "Cedar Only (no compiler)",
            "inherits": "debug",
            "cacheVariables": {
                "NKIDO_BUILD_AKKADO": "OFF",
                "NKIDO_BUILD_TOOLS": "ON"
            }
        },
        {
            "name": "coverage",
            "displayName": "Debug with Coverage",
            "inherits": "debug",
            "cacheVariables": {
                "NKIDO_ENABLE_COVERAGE": "ON"
            }
        },
        {
            "name": "minsize",
            "displayName": "Minimum Size (LTO, -Os)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
                "NKIDO_BUILD_TESTS": "OFF",
                "NKIDO_BUILD_TOOLS": "OFF",
                "NKIDO_BUILD_AKKADO": "OFF"
            }
        },
        {
            "name": "minsize-stripped",
            "displayName": "Minimum Size (no decoders/soundfont/FFT/minblep)",
            "inherits": "minsize",
            "cacheVariables": {
                "CEDAR_ENABLE_AUDIO_DECODERS": "OFF",
                "CEDAR_ENABLE_SOUNDFONT": "OFF",
                "CEDAR_ENABLE_FFT": "OFF",
                "CEDAR_ENABLE_FILE_IO": "OFF",
                "CEDAR_ENABLE_MINBLEP": "OFF"
            }
        },
        {
            "name": "esp32",
            "displayName": "ESP32 (reduced memory, no optional modules)",
            "inherits": "minsize-stripped",
            "cacheVariables": {
                "CEDAR_MAX_BUFFERS": "64",
                "CEDAR_MAX_STATES": "128",
                "CEDAR_MAX_VARS": "512",
                "CEDAR_MAX_PROGRAM_SIZE": "1024",
                "CEDAR_ARENA_SIZE": "262144",
                "CEDAR_FLOAT_ONLY": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "wasm",
            "configurePreset": "wasm"
        },
        {
            "name": "coverage",
            "configurePreset": "coverage"
        },
        {
            "name": "minsize",
            "configurePreset": "minsize"
        },
        {
            "name": "minsize-stripped",
            "configurePreset": "minsize-stripped"
        },
        {
            "name": "esp32",
            "configurePreset": "esp32"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
